# ============================================
# DATABASE — Neon PostgreSQL
# ============================================
DATABASE_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ============================================
# AUTH — Cookie signing
# ============================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET="change-this-to-a-random-secret"

# ============================================
# TELEGRAM BOT — Notifikasi Telegram (opsional)
# ============================================
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# ============================================
# WEB PUSH — Push Notifikasi Discord-style
# ============================================
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@mbg.app"
